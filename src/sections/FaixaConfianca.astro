---
import { Stethoscope, ClipboardList, MessageSquareText, MapPin } from '@lucide/astro';

const items = [
  {
    icon: Stethoscope,
    title: 'Avaliação com a Dra. Carolina',
    text: 'A conversa e o exame clínico são conduzidos pela profissional desde a primeira consulta.',
  },
  {
    icon: ClipboardList,
    title: 'Planejamento feito para o seu caso',
    text: 'A análise considera a condição dos dentes, da gengiva, da mordida e, caso tenha, das próteses existentes.',
  },
  {
    icon: MessageSquareText,
    title: 'Explicações fáceis de acompanhar',
    text: 'Você entende o que foi observado, quais exames podem ser necessários e que caminhos podem ser considerados.',
  },
  {
    icon: MapPin,
    title: 'Consultório no bairro das Graças',
    text: 'Atendimento no Kronos Empresarial, em Recife.',
  },
];
---

<section id="faixa-confianca" class="scroll-mt-20 bg-salvia-50 py-24 lg:py-36">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <h2 class="max-w-2xl text-h2 font-light text-tinta" data-reveal>
      Uma consulta para entender o que está acontecendo antes de definir o tratamento
    </h2>

    <div class="mt-16 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {
        items.map(({ icon: Icon, title, text }, index) => (
          <div data-reveal>
            <Icon size={26} stroke-width={1.5} class="text-salvia-600" />
            <h3 class="mt-4 font-semibold text-tinta">{title}</h3>
            <p class="mt-2 text-sm text-tinta-soft">{text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
