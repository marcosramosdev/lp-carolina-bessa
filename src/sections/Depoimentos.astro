---
// PLACEHOLDER: substituir os 3 cards abaixo pelos depoimentos reais assim que
// passarem pela validação técnica, ética e jurídica mencionada na copy (§ pendências).
import { Star } from "@lucide/astro";
import Eyebrow from "../components/Eyebrow.astro";

const placeholders = [1, 2, 3];
---

<section class="bg-creme py-24 lg:py-36">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="max-w-2xl" data-aos="fade-up">
      <Eyebrow tone="salvia">Depoimentos</Eyebrow>
      <h2 class="mt-5 text-h2 font-light text-tinta">
        O que dizem os pacientes atendidos pela Dra. Carolina
      </h2>
      <p class="mt-4 text-tinta-soft">
        Novos depoimentos serão publicados em breve, após validação.
      </p>
    </div>

    <div class="mt-16 grid gap-8 sm:grid-cols-3">
      {
        placeholders.map((n, index) => (
          <div
            class="rounded-2xl border border-dashed border-salvia-200 bg-salvia-50/40 p-7"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <div class="flex gap-0.5" aria-hidden="true">
              {Array.from({ length: 5 }).map(() => (
                <Star size={16} stroke-width={1.5} class="text-salvia-300" />
              ))}
            </div>
            <p class="mt-4 text-sm italic text-tinta-soft/70">
              Depoimento em validação — espaço reservado nº {n}.
            </p>
            <p class="mt-4 text-sm font-medium text-tinta-soft/70">Nome do paciente</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
