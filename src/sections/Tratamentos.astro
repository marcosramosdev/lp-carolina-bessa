---
import Eyebrow from "../components/Eyebrow.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { TREATMENTS, WA_MESSAGES } from "../consts";
---

<section id="tratamentos" class="scroll-mt-24 bg-creme py-24 lg:py-36">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="max-w-2xl">
      <Eyebrow tone="terracota">Tratamentos</Eyebrow>
      <h2 class="mt-5 text-h2 font-light text-tinta">
        Possibilidades avaliadas no consultório
      </h2>
    </div>

    <ul class="mt-10 flex flex-wrap gap-3">
      {
        TREATMENTS.map((treatment) => (
          <li class="rounded-full border border-salvia-200 bg-salvia-50/60 px-5 py-2.5 text-sm font-medium text-tinta">
            {treatment}
          </li>
        ))
      }
    </ul>

    <p class="mt-8 max-w-2xl text-sm italic text-tinta-soft/80">
      A presença de um procedimento nesta lista não significa que ele será indicado. A
      conduta depende do diagnóstico, do histórico e das condições clínicas de cada
      paciente.
    </p>

    <WhatsAppButton message={WA_MESSAGES.geral} label="Falar com a equipe" class="mt-8" />
  </div>
</section>
