---
import { Image } from "astro:assets";
import { Search, X } from "@lucide/astro";
import reabilitacao1 from "../assets/images/36.png";
import reabilitacao2 from "../assets/images/40.png";
import reabilitacao3 from "../assets/images/52.png";
import Eyebrow from "../components/Eyebrow.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { WA_MESSAGES } from "../consts";

const observations = [
  "A saúde dos dentes, da gengiva e dos tecidos de suporte",
  "A condição de próteses e restaurações existentes",
  "O encaixe da mordida e o equilíbrio das forças mastigatórias",
  "A presença de desgastes, perdas dentárias ou sobrecargas",
  "A necessidade de exames complementares",
  "Suas queixas, expectativas e objetivos",
];

const photos = [
  { src: reabilitacao1, alt: "Antes e depois de tratamento de reabilitação oral — caso 1" },
  { src: reabilitacao2, alt: "Antes e depois de tratamento de reabilitação oral — caso 2" },
  { src: reabilitacao3, alt: "Antes e depois de tratamento de reabilitação oral — caso 3" },
];
---

<section id="reabilitacao" class="scroll-mt-24 bg-creme py-24 lg:py-36">
  <div
    class="mx-auto grid max-w-7xl gap-16 px-6 lg:grid-cols-[380px_1fr] lg:items-center lg:gap-20 lg:px-10"
  >
    <div class="grid grid-cols-2 gap-4">
      {
        photos.map(({ src, alt }, index) => (
          <button
            type="button"
            data-lightbox-trigger={index}
            aria-label={`Ampliar imagem: ${alt}`}
            class={`group overflow-hidden rounded-2xl shadow-lg shadow-salvia-900/10 cursor-zoom-in ${
              index === 2 ? "col-span-2" : ""
            }`}
          >
            <Image
              src={src}
              alt={alt}
              widths={[380, 560, 760]}
              sizes="(min-width: 1024px) 380px, 90vw"
              loading="lazy"
              class="aspect-[4/5] w-full object-cover transition duration-300 group-hover:scale-105"
            />
          </button>
        ))
      }
    </div>

    <div>
      <Eyebrow tone="salvia">Reabilitação oral</Eyebrow>

      <h2 class="mt-5 text-h2 font-light text-tinta">
        Nem sempre o problema é apenas um dente
      </h2>

      <div class="mt-8 space-y-5 text-tinta-soft">
        <p>
          Você percebe que evita sorrir em algumas situações. Que já se acostumou a mastigar
          de um lado. Que sente um desconforto ao acordar, uma dor que aparece de vez em
          quando ou a sensação de que sua mordida já não é a mesma.
        </p>
        <p>
          Muitas pessoas convivem com esses sinais por anos, acreditando que fazem parte da
          rotina. Mas, quando um dente é perdido, desgastado ou deixa de exercer sua função
          adequadamente, toda a boca precisa se adaptar, e essas mudanças podem afetar o
          conforto, a estabilidade e a saúde do sorriso ao longo do tempo.
        </p>
      </div>

      <h3 class="mt-8 font-semibold text-tinta">
        Durante a consulta, a Dra. Carolina realiza uma avaliação cuidadosa para compreender
        como toda a boca está funcionando. São analisados:
      </h3>
      <ul class="mt-4 grid gap-3 sm:grid-cols-2">
        {
          observations.map((item) => (
            <li class="flex items-start gap-2.5 text-sm text-tinta-soft">
              <Search size={16} stroke-width={2} class="mt-0.5 shrink-0 text-salvia-600" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>

      <p class="mt-6 text-tinta-soft">
        Conforme as condições encontradas, podem ser considerados o uso de próteses, coroas,
        implantes, restaurações ou um planejamento que envolva mais de uma etapa.
      </p>

      <p class="mt-4 text-tinta-soft">
        Mais do que substituir um dente, a reabilitação oral busca devolver conforto,
        equilíbrio e a tranquilidade de voltar a sorrir com segurança e confiança.
      </p>

      <WhatsAppButton
        message={WA_MESSAGES.reabilitacao}
        label="Agendar consulta de reabilitação"
        class="mt-8"
      />
    </div>
  </div>

  <dialog
    id="reabilitacao-lightbox"
    aria-label="Imagem ampliada"
    class="m-auto max-h-[90vh] max-w-[90vw] bg-transparent p-0 backdrop:bg-tinta/80"
  >
    <button
      type="button"
      data-lightbox-close
      aria-label="Fechar"
      class="fixed top-4 right-4 z-20 flex h-10 w-10 items-center justify-center rounded-full bg-creme text-tinta shadow-lg ring-1 ring-salvia-200 transition hover:bg-terracota-50"
    >
      <X size={20} stroke-width={2} />
    </button>
    {
      photos.map(({ src, alt }, index) => (
        <Image
          src={src}
          alt={alt}
          data-lightbox-image={index}
          widths={[400, 700, 1000]}
          sizes="90vw"
          class="hidden max-h-[85vh] max-w-[90vw] w-auto rounded-2xl object-contain"
        />
      ))
    }
  </dialog>
</section>

<script>
  function setupLightbox() {
    const dialog = document.getElementById(
      "reabilitacao-lightbox",
    ) as HTMLDialogElement | null;
    if (!dialog) return;

    const triggers = dialog
      .closest("section")
      ?.querySelectorAll<HTMLButtonElement>("[data-lightbox-trigger]");
    const images = dialog.querySelectorAll<HTMLImageElement>(
      "[data-lightbox-image]",
    );
    const closeBtn = dialog.querySelector<HTMLButtonElement>(
      "[data-lightbox-close]",
    );

    triggers?.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const index = trigger.dataset.lightboxTrigger;
        images.forEach((img) => {
          img.classList.toggle(
            "hidden",
            img.dataset.lightboxImage !== index,
          );
        });
        dialog.showModal();
      });
    });

    closeBtn?.addEventListener("click", () => dialog.close());

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });
  }

  setupLightbox();
</script>
