---
import { UserCheck, Layers, Lightbulb, Leaf, PackageCheck, Clock } from "@lucide/astro";
import Eyebrow from "../components/Eyebrow.astro";

const items = [
  {
    icon: UserCheck,
    title: "Avaliação conduzida pela profissional",
    text: "Desde a primeira consulta, você pode conversar diretamente com a Dra. Carolina sobre sintomas, receios e expectativas.",
  },
  {
    icon: Layers,
    title: "Visão estética e reabilitadora",
    text: "A aparência do sorriso é analisada junto com a mastigação, a mordida e a saúde bucal.",
  },
  {
    icon: Lightbulb,
    title: "Explicações sem complicação",
    text: "A Dra. Carolina mostra o que está sendo avaliado e explica por que uma possibilidade pode ou não servir para o seu caso.",
  },
  {
    icon: Leaf,
    title: "Cuidado com resultados artificiais",
    text: "Em tratamentos estéticos, o planejamento respeita o rosto, as proporções dos dentes e as características naturais do sorriso.",
  },
  {
    icon: PackageCheck,
    title: "Materiais escolhidos conforme a indicação",
    text: "A seleção considera o tipo de procedimento, as condições clínicas e as necessidades do planejamento.",
  },
  {
    icon: Clock,
    title: "Tempo para pensar",
    text: "Você recebe as informações da avaliação e pode analisar os próximos passos antes de iniciar um tratamento.",
  },
];
---

<section class="bg-salvia-50 py-24 lg:py-36">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="max-w-2xl" data-reveal>
      <Eyebrow tone="salvia">Diferenciais</Eyebrow>
      <h2 class="mt-5 text-h2 font-light text-tinta">
        Informação suficiente para você decidir com segurança
      </h2>
    </div>

    <div class="mt-16 grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        items.map(({ icon: Icon, title, text }, index) => (
          <div data-reveal style={`transition-delay: ${index * 80}ms`}>
            <Icon size={26} stroke-width={1.5} class="text-salvia-600" />
            <h3 class="mt-4 font-semibold text-tinta">{title}</h3>
            <p class="mt-2 text-sm text-tinta-soft">{text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
