---
import { Quote } from '@lucide/astro';
import Eyebrow from '../components/Eyebrow.astro';

const objections = [
  {
    quote: 'Tenho medo de começar um tratamento.',
    answer:
      'Conte à Dra. Carolina sobre experiências anteriores e situações que deixaram você inseguro. Essas informações ajudam a conduzir a consulta e a explicar cada etapa com mais cuidado.',
  },
  {
    quote: 'Quero saber quanto vai custar.',
    answer:
      'O valor do tratamento depende do diagnóstico, dos materiais e da quantidade de etapas envolvidas. A equipe pode informar antecipadamente o valor da consulta inicial. O orçamento do tratamento é apresentado após a análise do caso.',
  },
  {
    quote: 'Tenho receio de ficar com um sorriso artificial.',
    answer:
      'O planejamento estético considera o formato dos dentes, a cor, a mordida e a relação do sorriso com o rosto. Também são respeitados os limites da saúde bucal e do procedimento escolhido. Antes da etapa definitiva, há uma validação do que será feito, para que você se sinta seguro com a estética escolhida. A filosofia de trabalho da Dra. Carolina é entregar resultados naturais.',
  },
  {
    quote: 'Já tive uma experiência ruim no dentista.',
    answer:
      'Você pode explicar o que aconteceu e o que mais preocupa você. A Dra. Carolina tem uma postura acolhedora e respeita os limites de cada paciente, para que você se sinta seguro durante todo o tratamento.',
  },
];
---

<section id="duvidas" class="scroll-mt-24 bg-lavanda-50 py-24 lg:py-36">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="max-w-2xl">
      <Eyebrow tone="lavanda">Dúvidas antes de marcar</Eyebrow>
      <h2 class="mt-5 text-h2 font-light text-tinta">
        O que costuma preocupar antes da primeira consulta
      </h2>
    </div>

    <div class="mt-16 grid gap-8 lg:grid-cols-2">
      {
        objections.map(({ quote, answer }, index) => (
          <div class="rounded-2xl bg-creme p-7">
            <Quote size={22} stroke-width={1.5} class="text-lavanda-400" />
            <p class="mt-3 text-lg font-medium text-tinta">“{quote}”</p>
            <p class="mt-3 text-sm text-tinta-soft">{answer}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
