---
import { Image } from "astro:assets";
import antesDepois1 from "../assets/images/antes-depois-1.jpg";
import antesDepois2 from "../assets/images/antes-depois-2.jpg";
import antesDepois3 from "../assets/images/antes-depois-3.jpg";
import Eyebrow from "../components/Eyebrow.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { WA_MESSAGES } from "../consts";

const cases = [
  { image: antesDepois1, caption: "Proporção e simetria" },
  { image: antesDepois2, caption: "Linha do sorriso" },
  { image: antesDepois3, caption: "Restauração e clareamento" },
];
---

<section class="bg-salvia-50 py-24 lg:py-36">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="max-w-2xl" data-reveal>
      <Eyebrow tone="terracota">Antes e depois</Eyebrow>
      <h2 class="mt-5 text-h2 font-light text-tinta">
        Resultados construídos a partir do planejamento de cada caso
      </h2>
      <p class="mt-6 text-tinta-soft">
        As imagens abaixo mostram casos reais acompanhados pela Dra. Carolina Bessa. Cada
        resultado partiu de uma avaliação individual, considerando a saúde bucal, a mordida
        e as características naturais do sorriso.
      </p>
    </div>

    <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        cases.map(({ image, caption }, index) => (
          <div data-reveal>
            <div class="overflow-hidden rounded-2xl shadow-lg shadow-salvia-900/10">
              <Image
                src={image}
                alt={`Antes e depois de tratamento odontológico — ${caption}`}
                widths={[400, 600, 800]}
                sizes="(min-width: 1024px) 380px, 90vw"
                loading="lazy"
                class="aspect-[4/5] w-full object-cover"
              />
            </div>
            <p class="mt-3 text-sm font-medium text-tinta-soft">{caption}</p>
          </div>
        ))
      }
    </div>

    <p class="mt-8 max-w-2xl text-sm italic text-tinta-soft/80">
      Os resultados apresentados refletem casos específicos. Cada tratamento depende do
      diagnóstico e das condições clínicas do paciente.
    </p>

    <WhatsAppButton
      message={WA_MESSAGES.estetica}
      label="Quero avaliar o meu caso"
      class="mt-8"
    />
  </div>
</section>
