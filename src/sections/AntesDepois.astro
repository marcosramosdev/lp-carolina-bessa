---
import { Image } from 'astro:assets';
import { ChevronLeft, ChevronRight } from '@lucide/astro';
import caso1 from '../assets/images/1.png';
import caso4 from '../assets/images/4(1).png';
import caso7 from '../assets/images/7.png';
import caso12 from '../assets/images/12.png';
import caso14 from '../assets/images/14.png';
import caso18 from '../assets/images/18.png';
import caso19 from '../assets/images/19.png';
import caso30 from '../assets/images/30.png';
import caso33 from '../assets/images/33.png';
import caso34 from '../assets/images/34.png';
import caso41 from '../assets/images/41.png';
import caso40 from '../assets/images/40.png';
import caso44 from '../assets/images/44.png';
import caso48 from '../assets/images/48.png';
import caso50 from '../assets/images/50.png';
import caso51 from '../assets/images/51.png';
import antesDepois1 from '../assets/images/antes-depois-1.jpg';
import antesDepois2 from '../assets/images/antes-depois-2.jpg';
import antesDepois3 from '../assets/images/antes-depois-3.jpg';
import Eyebrow from '../components/Eyebrow.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { WA_MESSAGES } from '../consts';

const cases = [
  {
    image: antesDepois1,
    caption: 'Reanatomização para harmonia das proporções dentárias',
  },
  {
    image: antesDepois2,
    caption: 'Correção da linha do sorriso com laminados cerâmicos',
  },
  {
    image: antesDepois3,
    caption: 'Uniformização de forma e cor com laminados cerâmicos',
  },
  { image: caso1, caption: 'Gengivoplastia e reanatomização' },
  { image: caso4, caption: 'Queixa inicial: sorriso infantil' },
  { image: caso7, caption: 'Gengivoplastia e reanatomização' },
  {
    image: caso14,
    caption: 'Proporção, alinhamento e ajuste de cor',
  },
  { image: caso18, caption: 'Proporção e alinhamento' },
  { image: caso30, caption: 'Alinhamento e coroa adesiva' },
  {
    image: caso33,
    caption: 'Alteração de forma e cor com laminados cerâmicos',
  },
  { image: caso34, caption: 'Fechamento de diastemas e reanatomização' },
  {
    image: caso12,
    caption:
      'Queixa inicial: mastigação e estética comprometidas. Final: devolvendo confiança para sorrir',
  },
  { image: caso41, caption: 'Ajuste estético e funcional' },
  { image: caso40, caption: 'Troca de prótese total removível' },
  {
    image: caso19,
    caption:
      'Queixa inicial: dificuldade de mastigação. Aspecto final: melhora estética e funcional',
  },
  { image: caso44, caption: 'Alinhamento e reanatomização estética' },
  {
    image: caso48,
    caption: 'Devolvendo segurança para sorrir com coroas em zircônia',
  },
  {
    image: caso50,
    caption:
      'Queixa inicial: dentes não apareciam ao sorrir. Aspecto final: dentes mais alongados, iluminados e alinhados (rejuvenescimento do sorriso)',
  },
  { image: caso51, caption: 'Ajuste de cor em dente escurecido' },
];
---

<section id="antes-e-depois" class="scroll-mt-24 bg-salvia-50 py-24 lg:py-36">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="max-w-2xl">
      <Eyebrow tone="terracota">Antes e depois</Eyebrow>
      <h2 class="mt-5 text-h2 font-light text-tinta">
        Resultados construídos a partir do planejamento de cada caso
      </h2>
      <p class="mt-6 text-tinta-soft">
        As imagens abaixo mostram casos reais acompanhados pela Dra. Carolina
        Bessa. Cada resultado partiu de uma avaliação individual, considerando a
        saúde bucal, a função e as características naturais do sorriso.
      </p>
    </div>

    <div class="relative mt-14">
      <ul
        id="antes-depois-track"
        class="no-scrollbar -mx-6 flex snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth px-6 pb-2 lg:mx-0 lg:px-0"
        aria-label="Galeria de casos de antes e depois"
      >
        {
          cases.map(({ image, caption }) => (
            <li class="w-[85%] shrink-0 snap-center sm:w-[calc((100%-1.5rem)/2)] sm:snap-start lg:w-[calc((100%-3rem)/3)]">
              <div class="overflow-hidden rounded-2xl shadow-lg shadow-salvia-900/10">
                <Image
                  src={image}
                  alt={`Antes e depois de tratamento odontológico — ${caption}`}
                  widths={[400, 600, 800]}
                  sizes="(min-width: 1024px) 380px, 85vw"
                  loading="lazy"
                  class="aspect-[4/5] w-full object-cover"
                />
              </div>
              <p class="mt-3 text-sm font-medium text-tinta-soft">{caption}</p>
            </li>
          ))
        }
      </ul>

      <button
        type="button"
        data-carousel-prev
        aria-label="Ver casos anteriores"
        class="absolute -left-3 top-1/3 z-10 flex h-11 w-11 items-center justify-center rounded-full bg-creme text-tinta shadow-lg ring-1 ring-salvia-200 transition hover:bg-terracota-50 disabled:pointer-events-none disabled:opacity-40 lg:-left-5"
      >
        <ChevronLeft size={22} stroke-width={2} />
      </button>
      <button
        type="button"
        data-carousel-next
        aria-label="Ver próximos casos"
        class="absolute -right-3 top-1/3 z-10 flex h-11 w-11 items-center justify-center rounded-full bg-creme text-tinta shadow-lg ring-1 ring-salvia-200 transition hover:bg-terracota-50 disabled:pointer-events-none disabled:opacity-40 lg:-right-5"
      >
        <ChevronRight size={22} stroke-width={2} />
      </button>
    </div>

    <p class="mt-8 max-w-2xl text-sm italic text-tinta-soft/80">
      Os resultados apresentados refletem casos específicos. Cada tratamento
      depende do diagnóstico e das condições clínicas do paciente.
    </p>

    <WhatsAppButton
      message={WA_MESSAGES.estetica}
      label="Quero avaliar o meu caso"
      class="mt-8"
    />
  </div>
</section>

<style>
  .no-scrollbar {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function setupCarousel() {
    const track = document.getElementById('antes-depois-track');
    if (!track) return;

    const section = track.closest('section');
    const prev = section?.querySelector<HTMLButtonElement>(
      '[data-carousel-prev]',
    );
    const next = section?.querySelector<HTMLButtonElement>(
      '[data-carousel-next]',
    );
    if (!prev || !next) return;

    const slideStep = () => {
      const slide = track.querySelector('li');
      if (!slide) return track.clientWidth;
      const gap = parseFloat(getComputedStyle(track).columnGap) || 0;
      return slide.getBoundingClientRect().width + gap;
    };

    prev.addEventListener('click', () => {
      track.scrollBy({ left: -slideStep(), behavior: 'smooth' });
    });
    next.addEventListener('click', () => {
      track.scrollBy({ left: slideStep(), behavior: 'smooth' });
    });

    const updateButtons = () => {
      const maxScroll = track.scrollWidth - track.clientWidth - 1;
      prev.disabled = track.scrollLeft <= 0;
      next.disabled = track.scrollLeft >= maxScroll;
    };

    track.addEventListener('scroll', updateButtons, { passive: true });
    window.addEventListener('resize', updateButtons);
    updateButtons();
  }

  setupCarousel();
</script>
