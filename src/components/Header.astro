---
import { Image } from 'astro:assets';
import { Menu, X } from '@lucide/astro';
import logo from '../assets/logo/logo-bessa.png';
import WhatsAppButton from './WhatsAppButton.astro';
import { NAV_LINKS, WA_MESSAGES } from '../consts';
---

<header
  class="sticky top-0 z-40 h-20 border-b border-salvia-100 bg-creme/90 backdrop-blur-sm"
>
  <div
    class="relative mx-auto flex h-full max-w-7xl items-center justify-between gap-4 px-6 lg:justify-end lg:px-10"
  >
    <a
      href="#"
      class="shrink-0 lg:absolute lg:left-1/2 lg:top-1/2 lg:-translate-x-1/2 lg:-translate-y-1/2"
    >
      <Image
        src={logo}
        alt="Dra. Carolina Bessa | Odontologia"
        width={200}
        densities={[2, 3]}
        class="h-auto w-40 sm:w-48"
      />
    </a>

    <div class="flex items-center gap-3 sm:gap-4">
      <div class="hidden md:inline-flex">
        <WhatsAppButton message={WA_MESSAGES.geral} label="Agendar consulta" />
      </div>

      <details id="header-menu" class="group relative">
        <summary
          class="flex cursor-pointer list-none items-center gap-2 rounded-full border border-salvia-200 px-4 py-2.5 text-sm font-medium text-tinta transition hover:border-salvia-300 hover:bg-salvia-50 [&::-webkit-details-marker]:hidden"
          aria-label="Abrir menu de navegação"
        >
          <span class="hidden sm:inline">Menu</span>
          <Menu size={20} stroke-width={2} class="group-open:hidden" />
          <X size={20} stroke-width={2} class="hidden group-open:block" />
        </summary>

        <nav
          class="absolute right-0 top-full mt-3 w-72 rounded-2xl border border-salvia-100 bg-creme p-3 shadow-xl shadow-salvia-900/10"
          aria-label="Navegação principal"
        >
          <ul class="flex flex-col">
            {
              NAV_LINKS.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="block rounded-xl px-4 py-2.5 text-sm font-medium text-tinta-soft transition hover:bg-salvia-50 hover:text-terracota-600"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
          <div class="mt-3 border-t border-salvia-100 pt-4 md:hidden">
            <WhatsAppButton
              message={WA_MESSAGES.geral}
              label="Agendar consulta"
              class="w-full"
            />
          </div>
        </nav>
      </details>
    </div>
  </div>
</header>

<script>
  const menu = document.getElementById(
    'header-menu',
  ) as HTMLDetailsElement | null;

  if (menu) {
    // Fecha ao clicar em um link do menu
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.open = false;
      });
    });

    // Fecha ao clicar fora
    document.addEventListener('click', (event) => {
      if (menu.open && !menu.contains(event.target as Node)) {
        menu.open = false;
      }
    });

    // Fecha com Esc
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') menu.open = false;
    });
  }
</script>
