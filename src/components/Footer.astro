---
import { Image } from "astro:assets";
import logo from "../assets/logo/CD_horizontal branco.png";
import { CLINIC, waLink, WA_MESSAGES } from "../consts";

const currentYear = new Date().getFullYear();

// Página de Política de Privacidade ainda não existe — link fica desativado até ser criada.
const footerLinks = [
  { label: "Início", href: "/" },
  { label: "Tratamentos", href: "#tratamentos" },
  { label: "Localização", href: "#localizacao" },
  { label: "Falar pelo WhatsApp", href: waLink(WA_MESSAGES.geral) },
];
---

<footer class="bg-tinta py-14 text-salvia-100">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_1fr_1fr]">
      <div>
        <Image src={logo} alt="Dra. Carolina Bessa | Odontologia" height={36} width={160} />
        <p class="mt-4 text-sm">{CLINIC.building}</p>
        <p class="text-sm">{CLINIC.street}, {CLINIC.suite}</p>
        <p class="text-sm">{CLINIC.neighborhood}</p>
      </div>

      <nav aria-label="Links do rodapé">
        <p class="text-eyebrow font-semibold uppercase text-salvia-300">Links</p>
        <ul class="mt-4 space-y-2.5">
          {
            footerLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm hover:text-creme">
                  {link.label}
                </a>
              </li>
            ))
          }
          <li class="text-sm text-salvia-400">Política de Privacidade (em preparação)</li>
        </ul>
      </nav>

      <div>
        <p class="text-eyebrow font-semibold uppercase text-salvia-300">Dados profissionais</p>
        <p class="mt-4 text-sm">{CLINIC.cro}</p>
        <p class="mt-4 text-xs leading-relaxed text-salvia-300">
          As informações desta página têm caráter informativo e não substituem uma
          avaliação odontológica. A indicação de qualquer tratamento depende da análise
          individual do paciente.
        </p>
      </div>
    </div>

    <p class="mt-10 border-t border-salvia-700/60 pt-6 text-xs text-salvia-400">
      © {currentYear} Dra. Carolina Bessa | Odontologia. Todos os direitos reservados.
    </p>
  </div>
</footer>
